  "lambda_tensor": 0.0,
  "best_model_metric": "diag_score",
  "diag_score_weights": {
    "xx": 1,
    "yy": 1,
    "xy": 1
  },
  "diag_score_normalization": "train_mae_scale",
  "loss_ws": 1.0,
  "loss_irrep_weights": {
    "trace": 1.0,
    "anisotropy": 1.0,
    "shear": 1.0
  }
