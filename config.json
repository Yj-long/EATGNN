{
  "seed": 42,
  "device": "cuda",
  "structure_path": "structures.json",
  "label_path": "dataset.json",
  "structure_uid_key": "uid",
  "structure_key": "structure",
  "label_uid_key": "uid",
  "target_key": "total",
  "use_magpie_descriptors": true,
  "extra_atom_descriptor_path": null,
  "extra_atom_descriptor_key": "element",
  "extra_atom_descriptor_columns": null,
  "extra_atom_descriptor_missing_value": 0.0,
  "global_descriptor_path": [
    "eatgnn_aux_physical_priors.csv",
    "stage1_oof_tail_hints.csv"
  ],
  "global_descriptor_uid_key": "uid",
  "global_descriptor_columns": [
    null,
    [
      "hint_p_tail_class_raw",
      "hint_p_tail_binary_raw",
      "hint_p_tail_binary_calibrated",
      "hint_z_tail_pred",
      "hint_tail_score_fused",
      "hint_c_pred"
    ]
  ],
  "global_descriptor_missing_value": 0.0,
  "use_global_descriptor_gating": true,
  "target_transform": {
    "enabled": true,
    "method": "signed_log1p_robust",
    "eps": 1e-06
